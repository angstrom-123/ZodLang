include "std.lang"

i64 add_with_10(i64 a, i64 b) {
    i64 c = 10;
    return a + b + c;
}

i64 no_args() {
    return 100;
}

i64 main() {
    putd(add_with_10(2, 3));
    putd(add_with_10(5, 6));
    i64 a = add_with_10(1 + 2 * 3, 6 / 2);
    putd(a);
    putd(add_with_10(no_args(), no_args()));
    exit(0);
}
