include "std.zod"

i64 main() {
    putd(strlen("Hello, World!\n"));

    putd(strlen("Hello, World!\n"));

    any^ str = "Hello, World!\n";
    syscall(1, 1, str, 14);

    syscall(1, 1, "Hello, World!\n", 14);

    putd(strlen("Hello, World!\n"));
    puts("Hello, World!\n");

    chr^ a = malloc(4096);
    a[0] = 'a';
    a[1] = '\n';
    puts(a);
    munmap(a, 4096);

    puts("hello\n");

    exit(0);
}
