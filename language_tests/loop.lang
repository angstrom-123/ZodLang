include "std.lang"

i64 main() {
    for i64 i = 0; i < 5; i = i + 1 {
        putd(i);
    }

    for i64 i = 0; i < 5; i = i + 1 {
        putd(i);
    }

    for i64 i = 0; i < 5; {
        putd(i);
        i = i + 1;
    }

    for i64 i = 4; 
            i >= 0; 
            i = i - 1 {
        putd(i);
    }

    i64 i;
    for ; i < 5; i = i + 1 {
        putd(i);
    }

    i = 0;
    for ; i < 5; {
        putd(i);
        i = i + 1;
    }

    for i64 j = 0; j < 10; j = j + 1 {
        putd(j);
        if j >= 5 {
            break;
        }
    }

    for i64 j = 0; j < 10; j = j + 1 {
        if j <= 5 {
            continue;
        }

        putd(j);
    }

    i = 0;
    for ; i < 10; i = i + 1 {
        if i == 2 || i == 4 || i == 6 || i == 8 {
            continue;
        }
        putd(i);
    }
    putd(i);

    i = 0;
    for ; i < 10; {
        if i == 4 {
            break;
        }
        putd(i);
        i = i + 1;
    }
    putd(i);

    i = 0;
    while i < 10 {
        putd(i);
        i = i + 1;
    }

    i64 ctr = 0;
    while 1 {
        ctr = ctr + 1;

        if ctr == 5 {
            continue;
        }
        if ctr == 10 {
            break;
        }

        putd(ctr);
    }

    exit(0);
}
