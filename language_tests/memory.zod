include "std.zod"

i64 main() {
    test_one();
    test_two();
    exit(0);
}

i64 test_one() {
    i64^ mem = malloc(4096);

    @mem = 10;

    mem = mem + 8;
    @mem = 20;

    mem = mem + 8;
    @mem = 30;

    mem = mem + 8;
    @mem = 40;

    mem = mem - 24;
    writed(@mem);
    writed(@(mem + 8));
    writed(@(mem + 16));
    writed(@(mem + 24));

    munmap(mem, 4096);
}

i64 test_two() {
    i64^ mem = malloc(4096);

    writed(1);
    @(mem) = 100;
    writed(2);
    @(mem + 8) = 200;
    writed(3);
    writed(@mem);
    writed(4);
    writed(@(mem + 8));
    writed(5);

    munmap(mem, 4096);
}
