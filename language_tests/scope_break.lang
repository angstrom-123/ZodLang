include "std.lang"

i64 test_for_loop() {
    for i64 i = 0; i < 10; i = i + 1 {
        putd(i);
        for i64 j = 0; j < 10; j = j + 1 {
            putd(100 + j);
            if j == 5 {
                break;
            }
        }

        putd(200 + i);
        if i == 5 {
            break;
        }
    }

    return 0;
}

i64 test_while_loop() {
    i64 i = 0;
    while i < 10 {
        putd(i);
        for i64 j = 0; j < 10; j = j + 1 {
            putd(100 + j);
            if j == 5 {
                break;
            }
        }

        putd(200 + i);
        if i == 5 {
            break;
        }

        i = i + 1;
    }

    return 0;
}

i64 main() {
    test_for_loop();
    test_while_loop();
    exit(0);
}
