include "std.lang"

i64 main() {
    test_one();
    test_two();
    exit(0);
}

i64 test_one() {
    i64^ mem = malloc(4096);

    @mem = 10;

    mem = mem + 8;
    @mem = 20;

    mem = mem + 8;
    @mem = 30;

    mem = mem + 8;
    @mem = 40;

    mem = mem - 24;
    putd(@mem);
    putd(@(mem + 8));
    putd(@(mem + 16));
    putd(@(mem + 24));

    munmap(mem, 4096);
}

i64 test_two() {
    i64^ mem = malloc(4096);

    putd(1);
    @(mem) = 100;
    putd(2);
    @(mem + 8) = 200;
    putd(3);
    putd(@mem);
    putd(4);
    putd(@(mem + 8));
    putd(5);

    munmap(mem, 4096);
}
