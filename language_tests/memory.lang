i64 main() {
    test_one();
    test_two();
    exit(0);
}

i64 test_one() {
    i64^ mem = mmap(4096);

    @mem = 10;

    mem = mem + 8p;
    @mem = 20;

    mem = mem + 8p;
    @mem = 30;

    mem = mem + 8p;
    @mem = 40;

    mem = mem - 24p;
    dump(@mem);
    dump(@(mem + 8p));
    dump(@(mem + 16p));
    dump(@(mem + 24p));

    munmap(mem, 4096);
}

i64 test_two() {
    i64^ mem = mmap(4096);

    dump(1);
    @(mem) = 100;
    dump(2);
    @(mem + 8p) = 200;
    dump(3);
    dump(@mem);
    dump(4);
    dump(@(mem + 8p));
    dump(5);

    munmap(mem, 4096);
}
