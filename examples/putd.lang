void main() {
    putd(10 + 1 + 2 - 4 * 2 + 10);

    syscall(60, 0);
}

void putd(i64 x) {
    chr^ buf = syscall(9, 0, 4096, 3, 34, 0, -1);
    i64 max_size = 32;
    i64 size = 0;
    while x {
        buf[max_size - size - 1] = x % 10 + '0';
        size = size + 1;
        x = x / 10;
    }

    buf[max_size] = '\n';
    syscall(1, 1, buf + max_size - size, 3);
}
